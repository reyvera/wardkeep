    "eslint": "^8.57.0",
    "prettier": "^3.2.0",
    "prisma": "^5.14.0",
    "tsx": "^4.11.0",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
