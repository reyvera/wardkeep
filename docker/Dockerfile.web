# =============================================================================
# Wardkeep Web — Docker Image
#
# Key decisions:
# - Uses Next.js standalone output mode (configured in next.config.js).
# - In a pnpm monorepo, standalone outputs server.js at apps/web/server.js
#   (not the root), with the full monorepo structure embedded.
# - Static files and public assets must be copied to paths relative to server.js.
# - NEXT_PUBLIC_API_URL is baked in at build time (ARG) since Next.js inlines
#   env vars prefixed with NEXT_PUBLIC_ during the build.
# =============================================================================

FROM node:22-alpine AS builder
WORKDIR /app

ARG NEXT_PUBLIC_API_URL=http://localhost:4000/api

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml turbo.json tsconfig.base.json ./
COPY packages/ packages/
COPY apps/web/ apps/web/
RUN corepack enable && pnpm install --frozen-lockfile

ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL
RUN pnpm turbo build --filter=@wardkeep/web

FROM node:22-alpine AS runner
WORKDIR /app
RUN apk add --no-cache wget
ENV NODE_ENV=production
ENV PORT=3000
ENV HOSTNAME="0.0.0.0"

# Next.js standalone in monorepos outputs server.js under the app path
COPY --from=builder /app/apps/web/.next/standalone ./
COPY --from=builder /app/apps/web/.next/static ./apps/web/.next/static
COPY --from=builder /app/apps/web/public ./apps/web/public

EXPOSE 3000
CMD ["node", "apps/web/server.js"]
