{
  "name": "@wardkeep/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "swc src -d dist --strip-leading-paths --config-file .swcrc",
    "build:check": "tsc --project tsconfig.json --noEmit",
    "start": "node dist/main.js",
    "start:dev": "ts-node --project tsconfig.json src/main.ts",
    "test": "vitest run",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@wardkeep/ai-engine": "workspace:*",
    "@wardkeep/finance-engine": "workspace:*",
    "@wardkeep/importers": "workspace:*",
    "@wardkeep/shared": "workspace:*",
    "@nestjs/common": "^10.3.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/platform-socket.io": "^10.3.0",
    "@nestjs/throttler": "^5.2.0",
    "@nestjs/websockets": "^10.3.0",
    "@prisma/client": "^5.14.0",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "decimal.js": "^10.6.0",
    "dotenv": "^17.4.2",
    "helmet": "^7.1.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.7.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.0",
    "@nestjs/testing": "^10.3.0",
    "@swc/cli": "^0.5.0",
    "@swc/core": "^1.15.43",
    "@swc/register": "^0.1.10",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.21",
    "fast-check": "^4.8.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
