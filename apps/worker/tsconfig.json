{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "target": "ES2021",
    "outDir": "./dist",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "paths": {
      "@wardkeep/shared": ["../../packages/shared/src/index.ts"],
      "@wardkeep/finance-engine": ["../../packages/finance-engine/src/index.ts"],
      "@wardkeep/ai-engine": ["../../packages/ai-engine/src/index.ts"],
      "@wardkeep/importers": ["../../packages/importers/src/index.ts"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
