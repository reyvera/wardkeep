{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noUncheckedIndexedAccess": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "exactOptionalPropertyTypes": false,
    "paths": {
      "@wardkeep/shared": ["./packages/shared/src/index.ts"],
      "@wardkeep/finance-engine": ["./packages/finance-engine/src/index.ts"],
      "@wardkeep/ai-engine": ["./packages/ai-engine/src/index.ts"],
      "@wardkeep/importers": ["./packages/importers/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
