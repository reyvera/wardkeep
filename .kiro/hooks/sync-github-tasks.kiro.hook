{
  "enabled": true,
  "name": "Sync Tasks to GitHub on Stop",
  "description": "After agent execution, runs the sync script to close any GitHub issues that match the latest commit message keywords.",
  "version": "1.0.0",
  "when": {
    "type": "agentStop"
  },
  "then": {
    "type": "runCommand",
    "command": "source ~/.bashrc 2>/dev/null; cd /home/prosoft/random/budgetapp && bash scripts/sync-tasks-to-github.sh"
  }
}
