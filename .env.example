# =============================================================================
# BudgetApp Environment Configuration
# =============================================================================
# Minimum Hardware Requirements:
#   - 4 CPU cores (8 recommended for local AI)
#   - 8 GB RAM (16 GB recommended for Ollama models)
#   - 20 GB disk space (for Docker images, DB data, and AI models)
# =============================================================================

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/budgetapp?schema=public"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# API Server
PORT=4000

# Session & Security
SESSION_TIMEOUT=30
ENCRYPTION_KEY=change-me-in-production

# AI Configuration
AI_PRIVACY_MODE=LOCAL
OLLAMA_URL=http://localhost:11434

# Docker Compose overrides (used by docker-compose.yml)
# ENCRYPTION_KEY=generate-a-secure-random-key-here
