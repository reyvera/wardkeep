# =============================================================================
# Wardkeep Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# IMPORTANT: Generate a unique ENCRYPTION_KEY before first run:
#   openssl rand -hex 32
# =============================================================================

# ─── Security ────────────────────────────────────────────────────────────────
# REQUIRED: Set a unique 32+ character hex string. The app will refuse to start
# with the default value in production.
ENCRYPTION_KEY=change-me-in-production

# Session inactivity timeout in minutes (default: 30)
SESSION_TIMEOUT=30

# ─── Database ────────────────────────────────────────────────────────────────
# Must match docker-compose postgres service credentials
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=wardkeep
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/wardkeep?schema=public"

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── API Server ──────────────────────────────────────────────────────────────
PORT=4000

# ─── Ports (for docker-compose.prod.yml) ─────────────────────────────────────
WEB_PORT=3000
API_PORT=4000
POSTGRES_PORT=5432

# ─── AI Configuration ────────────────────────────────────────────────────────
# Modes: LOCAL (Ollama only), HYBRID (sensitive local, general cloud), CLOUD (all cloud)
# AI mode is also configurable per-user in the Settings page
AI_PRIVACY_MODE=LOCAL
OLLAMA_URL=http://localhost:11434

# Cloud AI keys (optional — can also be set per-user in Settings page)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# ─── Hardware Requirements ───────────────────────────────────────────────────
# Without local AI: 2 GB RAM, 2 CPU cores, 10 GB storage
# With local AI (Ollama): 8 GB RAM, 4 CPU cores, 20 GB storage
