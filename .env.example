# =============================================================================
# BudgetApp Environment Configuration
# =============================================================================
# Minimum Hardware Requirements:
#   Without local AI: 2 GB RAM, 2 CPU cores, 10 GB storage
#   With local AI (Ollama): 8 GB RAM, 4 CPU cores, 20 GB storage
# =============================================================================

# Database (must match docker-compose postgres service credentials)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/budgetapp?schema=public"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# API Server
PORT=4000

# Session & Security
SESSION_TIMEOUT=30
ENCRYPTION_KEY=change-me-in-production

# AI Configuration
# Modes: LOCAL (Ollama only), HYBRID (sensitive local, general cloud), CLOUD (all cloud)
# AI mode is also configurable per-user in the Settings page
AI_PRIVACY_MODE=LOCAL
OLLAMA_URL=http://localhost:11434

# Cloud AI keys (optional — can also be set per-user in Settings page)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
